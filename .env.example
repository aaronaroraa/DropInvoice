# FastAPI
APP_NAME=DropInvoice
APP_ENV=local
PUBLIC_BASE_URL=https://your-ngrok-or-host.example.com
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Twilio WhatsApp Business API
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Gemini API
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Gmail SMTP
GMAIL_SMTP_HOST=smtp.gmail.com
GMAIL_SMTP_PORT=587
GMAIL_USERNAME=your_email@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password

# Celery / Redis
REDIS_URL=redis://localhost:6379/0

# OCR / ASR
TESSERACT_CMD=/usr/bin/tesseract
WHISPER_MODEL=base

# Pipeline
# USE_CELERY=true   # optional async queue; default runs in-process

# Interactive menu before generating (GST? Tally? Sales/Salary?)
#   always    = ask for every bill (safest, default) — #flags still skip it
#   ambiguous = ask only when a text message is unclear
#   off       = never ask (pure auto-detect)
MENU_MODE=always

# Tally integration (auto-post invoices as Sales Vouchers)
# Enable Tally as Server: Help -> Settings -> Connectivity -> Client/Server,
# "Tally is acting as Server", port 9000.
TALLY_ENABLED=false
TALLY_URL=http://localhost:9000
TALLY_COMPANY=Your Company Name In Tally
TALLY_SALES_LEDGER=Sales
TALLY_DEFAULT_PARTY=Cash
TALLY_CGST_LEDGER=Output CGST
TALLY_SGST_LEDGER=Output SGST
TALLY_IGST_LEDGER=Output IGST

